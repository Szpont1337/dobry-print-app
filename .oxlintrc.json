{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "jsx-a11y",
    "nextjs",
    "import"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "ignorePatterns": [
    ".next",
    "node_modules",
    "next-env.d.ts"
  ]
}
